# 本番用環境変数の例（Render 等のダッシュボードに設定。.env は本番では使わなくても可）
# 値はクォート不要。秘密は Git に載せない。

# 必須: ブラウザに出るURLの土台（https、末尾スラッシュなし）
PUBLIC_BASE_URL=https://your-service.onrender.com

# 必須: ライブ課金なら sk_live_...（テストのまま運用するなら sk_test_）
STRIPE_SECRET_KEY=

# 必須: セッション用。ランダムな長い文字列を生成して設定
FLASK_SECRET_KEY=

# 任意: パック3プランを売るとき
# STRIPE_PRICE_LIGHT=
# STRIPE_PRICE_STANDARD=
# STRIPE_PRICE_RETAINER=

# 任意
# IDEA_DEFAULT_MONTHLY_JPY=2000
# STRIPE_WEBHOOK_SECRET=
# FULFILLMENT_WEBHOOK_URL=
# POST_PURCHASE_DELIVERY_URL=
