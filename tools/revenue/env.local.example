# このファイルをコピーして「.env」にリネームし、値を埋める。
# 場所: tools/revenue/.env （server.py と同じフォルダ）
# .env は Git に上げないこと。

STRIPE_SECRET_KEY=sk_test_ここに貼る
STRIPE_PRICE_LIGHT=price_ここに貼る
STRIPE_PRICE_STANDARD=price_ここに貼る
STRIPE_PRICE_RETAINER=price_ここに貼る
PUBLIC_BASE_URL=http://127.0.0.1:5000

# 100案それぞれの月額デフォルト（円）。案ごとに変えたい場合は ideas_catalog.json の monthly_jpy
IDEA_DEFAULT_MONTHLY_JPY=2000

# 任意
# POST_PURCHASE_DELIVERY_URL=https://...
